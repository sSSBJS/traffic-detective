# OpenAI report generation
# Leave empty to use the local fallback report.
OPENAI_API_KEY=
OPENAI_REPORT_MODEL=gpt-5-mini
OPENAI_REPORT_TIMEOUT_SECONDS=45

# Admin endpoint authentication
# Used by POST /api/v1/admin/update-model via the x-admin-token header.
MODEL_ADMIN_TOKEN=change-me

# Runtime model integration
# Set these when the real traffic forecasting model files are added.
# Expected evaluator result:
#   { model_key, display_name, order, rmse, smape, r2, predictions, actuals }
MODEL_LOADER_MODULE=
MODEL_EVALUATOR_MODULE=
MODEL_TRAINER_MODULE=

# Evaluation simulation controls
# Keeps mock batch evaluation visible while the real model is not connected.
BATCH_EVALUATION_DELAY_SECONDS=1.25

# Retraining policy
# Mirrors traffic-aiops-studio/backend/app/services/retraining.py.
RETRAINING_THRESHOLD_RATIO=0.15
RETRAINING_STALE_AFTER_DAYS=30
